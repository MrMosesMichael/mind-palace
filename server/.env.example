# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_base64_64

# CORS (comma-separated origins)
CORS_ORIGIN=https://mind.mdmichael.com

# Data paths (defaults work in Docker, override for local dev)
DATA_DIR=/data
DB_PATH=/data/db/mind-palace.sqlite
PHOTOS_DIR=/data/photos

# Initial admin account (used on first run)
ADMIN_USERNAME=moses
ADMIN_PASSWORD=CHANGE_ME
